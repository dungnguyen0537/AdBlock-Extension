{
  "manifest_version": 3,
  "name": "DShineeTools | YouTube + Spotify",
  "description": "Ad-block extension for YouTube and Spotify with a Vietnamese + English control center.",
  "version": "0.1.0",
  "minimum_chrome_version": "120",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://music.youtube.com/*",
    "*://*.ytimg.com/*",
    "*://*.googlevideo.com/*",
    "*://open.spotify.com/*",
    "*://*.spotify.com/*",
    "*://*.scdn.co/*",
    "*://*.doubleclick.net/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "DShineeTools",
    "default_popup": "popup/popup.html"
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://music.youtube.com/*"
      ],
      "js": [
        "src/injected/youtube-page.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://music.youtube.com/*"
      ],
      "js": [
        "src/shared/content-helpers.js",
        "src/content/youtube.js"
      ],
      "css": [
        "src/content/platform.css"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://open.spotify.com/*"
      ],
      "js": [
        "src/shared/content-helpers.js",
        "src/content/spotify.js"
      ],
      "css": [
        "src/content/platform.css"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/injected/spotify-page.js",
        "assets/logo.svg"
      ],
      "matches": [
        "*://*.youtube.com/*",
        "*://music.youtube.com/*",
        "*://open.spotify.com/*"
      ]
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "youtube-base",
        "enabled": true,
        "path": "rules/youtube-rules.json"
      },
      {
        "id": "spotify-base",
        "enabled": true,
        "path": "rules/spotify-rules.json"
      }
    ]
  }
}
